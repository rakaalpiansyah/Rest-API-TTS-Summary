# ─── Application ─────────────────────────────────────────────
APP_NAME="FastAPI AI Vcols"
APP_VERSION="1.0.0"
DEBUG=True
API_KEYS=key1,key2,key3    # comma-separated, API keys untuk client

# ─── AI Services ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-dari-google-ai-studio
GROQ_API_KEY=your-groq-api-key-dari-console-groq-com

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── CORS (Frontend URL) ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
